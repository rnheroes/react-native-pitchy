ws_dir = Pathname.new(__dir__)
ws_dir = ws_dir.parent until
  File.exist?("#{ws_dir}/node_modules/react-native-test-app/test_app.rb") ||
  ws_dir.expand_path.to_s == '/'
require "#{ws_dir}/node_modules/react-native-test-app/test_app.rb"

workspace 'PitchyExample.xcworkspace'

use_test_app!({
  post_install: proc do |installer|
    # Add NSMicrophoneUsageDescription to generated Info.plist
    info_plist_path = File.join(__dir__, '..', 'node_modules', '.generated', 'ios', 'Info.plist')
    if File.exist?(info_plist_path)
      system("/usr/libexec/PlistBuddy -c \"Add :NSMicrophoneUsageDescription string 'This app needs access to the microphone for pitch detection'\" \"#{info_plist_path}\" 2>/dev/null")
    end
  end
})

def node_require(script)
  # Resolve script with node to allow for hoisting
  require Pod::Executable.execute_command('node', ['-p',
    "require.resolve(
      '#{script}',
      {paths: [process.argv[1]]},
    )", __dir__]).strip
end

# Use it to require both react-native's and this package's scripts:
node_require('react-native-permissions/scripts/setup.rb')

setup_permissions([
  'Microphone'
])
